[
  {
    "id": "TC001",
    "title": "Create a new student with valid details and see it in the list",
    "description": "Verifies a user can add a student via the modal using valid CPF, phone, and complete address, and the student appears in the listing.",
    "category": "Student Management",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email/username field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click on the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/app\""
      },
      {
        "type": "action",
        "description": "Click on \"Alunos\" in the main navigation/menu"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/app/alunos"
      },
      {
        "type": "action",
        "description": "Click on the \"Add new student\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Novo aluno\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Aluno Teste E2E\" into the \"Full name\" field"
      },
      {
        "type": "action",
        "description": "Type \"123.456.789-10\" into the \"CPF\" field"
      },
      {
        "type": "action",
        "description": "Type \"11987654321\" into the \"Phone\" field"
      },
      {
        "type": "action",
        "description": "Type \"Rua das Flores\" into the \"Street\" field"
      },
      {
        "type": "action",
        "description": "Type \"100\" into the \"Number\" field"
      },
      {
        "type": "action",
        "description": "Type \"Centro\" into the \"Neighborhood\" field"
      },
      {
        "type": "action",
        "description": "Type \"São Paulo\" into the \"City\" field"
      },
      {
        "type": "action",
        "description": "Type \"SP\" into the \"State\" field"
      },
      {
        "type": "action",
        "description": "Type \"01001000\" into the \"ZIP\" field"
      },
      {
        "type": "action",
        "description": "Click on the \"Save student\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Aluno Teste E2E\" is visible"
      }
    ]
  },
