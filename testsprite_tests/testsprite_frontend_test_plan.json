  {
    "id": "TC009",
    "title": "Create and save a workout with one exercise (reps as range string)",
    "description": "Verifies a trainer can create a workout for a selected student with an exercise and reps entered as a range string, and the workout appears in the student’s list.",
    "category": "Workout Prescription",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/app\""
      },
      {
        "type": "action",
        "description": "Click on \"Treinos\" in the main navigation"
      },
      {
        "type": "action",
        "description": "Select a student from the student selector"
      },
      {
        "type": "action",
        "description": "Click \"Add Workout\""
      },
      {
        "type": "action",
        "description": "Click \"Add exercise to workout\""
      },
      {
        "type": "action",
        "description": "Choose an exercise from the exercise library list"
      },
      {
        "type": "action",
        "description": "Type \"3\" into the sets field"
      },
      {
        "type": "action",
        "description": "Type \"10-12\" into the reps field"
      },
      {
        "type": "action",
        "description": "Click \"Save workout\""
      },
      {
        "type": "assertion",
        "description": "Verify the workout is visible in the workout list for the selected student"
      }
    ]
  },
