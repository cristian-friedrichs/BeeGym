# ============================================================
# BeeGym Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env or .env.local to the repository.

# -- Google Gemini AI --
GEMINI_API_KEY=your_gemini_api_key_here

# -- Supabase --
# These two MUST keep the NEXT_PUBLIC_ prefix (required by browser Supabase client)
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only (NEVER expose to the client)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# -- EFI Integration (ALL server-only) --
# Ambiente: "homologacao" ou "producao"
EFI_AMBIENTE=homologacao

# Identificador de Conta EFI (payee_code)
EFI_PAYEE_CODE=

# Credenciais Homologacao
EFI_CLIENT_ID_HML=
EFI_CLIENT_SECRET_HML=
EFI_BASE_URL_HML=https://pix-h.api.efipay.com.br
EFI_OAUTH_URL_HML=https://pix-h.api.efipay.com.br/oauth/token
EFI_COBRANCAS_URL_HML=https://cobrancas-h.api.efipay.com.br

# Credenciais Producao
EFI_CLIENT_ID_PRD=
EFI_CLIENT_SECRET_PRD=
EFI_BASE_URL_PRD=https://pix.api.efipay.com.br
EFI_OAUTH_URL_PRD=https://pix.api.efipay.com.br/oauth/token
EFI_COBRANCAS_URL_PRD=https://api.efipay.com.br

# Certificado mTLS (caminho do arquivo OU base64)
EFI_CERT_PATH=
EFI_CERT_BASE64=
EFI_CERT_PASSWORD=

# Chave Pix Automatico
EFI_CHAVE_PIX_AUTOMATICO_HML=
EFI_CHAVE_PIX_AUTOMATICO_PRD=

# -- Webhook Secrets (OBRIGATORIO em producao) --
EFI_WEBHOOK_PIX_AUTOMATICO_SECRET=
EFI_WEBHOOK_CARD_RECORRENTE_SECRET=

# -- Aplicacao --
APP_URL=https://app.beegym.com.br

# Configuracoes de carencia
SUBSCRIPTION_GRACE_PERIOD_DAYS=3
SUBSCRIPTION_RETRY_INTERVAL_HOURS=24