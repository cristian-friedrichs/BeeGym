# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Database
# Connect to Supabase via connection pooling with Supavisor.
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true
# Direct connection to the database. Used for migrations.
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Supabase API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# === EFI GATEWAY ===

# Ambiente: "homologacao" ou "producao"
EFI_AMBIENTE=homologacao

# Credenciais de HomologaĂ§ĂŁo
EFI_CLIENT_ID_HML=
EFI_CLIENT_SECRET_HML=

# Credenciais de ProduĂ§ĂŁo
EFI_CLIENT_ID_PRD=
EFI_CLIENT_SECRET_PRD=

# Certificado mTLS (caminho para o arquivo .p12 baixado do portal EFI)
EFI_CERT_PATH=./certs/efi-certificado.p12
EFI_CERT_PASSWORD=

# Webhook
EFI_WEBHOOK_SECRET=

# URLs base (nĂŁo alterar)
EFI_BASE_URL_HML=https://pix-h.api.efipay.com.br
EFI_BASE_URL_PRD=https://pix.api.efipay.com.br
EFI_OAUTH_URL_HML=https://cobrancas-h.api.efipay.com.br/v1/authorize
EFI_OAUTH_URL_PRD=https://cobrancas.api.efipay.com.br/v1/authorize

# === RECORRĂNCIA V2 ===

# Pix AutomĂĄtico
EFI_CHAVE_PIX_AUTOMATICO_HML=chave-pix-beegym-hml@email.com
EFI_CHAVE_PIX_AUTOMATICO_PRD=chave-pix-beegym@beegym.com.br
EFI_WEBHOOK_PIX_AUTOMATICO_SECRET=secret-pix-automatico

# CartĂŁo Recorrente
EFI_WEBHOOK_CARD_RECORRENTE_SECRET=secret-card-recorrente

# ConfiguraĂ§Ă”es de carĂȘncia
SUBSCRIPTION_GRACE_PERIOD_DAYS=3
SUBSCRIPTION_RETRY_INTERVAL_HOURS=24

# URL de retorno apĂłs consentimento Pix AutomĂĄtico
APP_URL=https://app.beegym.com.br

# IDs dos planos criados no portal EFI
EFI_PLAN_ID_STARTER_HML=123
EFI_PLAN_ID_PRO_HML=124
EFI_PLAN_ID_ENTERPRISE_HML=125
EFI_PLAN_ID_STARTER_PRD=456
EFI_PLAN_ID_PRO_PRD=457
EFI_PLAN_ID_ENTERPRISE_PRD=458

# Identificador de Conta EFI (payee_code) - Encontrado em: Portal EFI ? API ? Introduçăo ? Identificador de Conta
NEXT_PUBLIC_EFI_PAYEE_CODE=

# Ambiente EFI (homologacao ou producao)
NEXT_PUBLIC_EFI_AMBIENTE=homologacao
